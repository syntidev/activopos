generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

// ── Enums ──────────────────────────────────────────────

enum Role {
  super_admin
  admin
  cashier
}

enum SaleMode {
  unit
  weight
  service
  length
  volume
  package
}

enum OrderStatus {
  received
  preparing
  ready
  dispatched
  delivered
  cancelled
}

enum OrderOrigin {
  whatsapp
  catalog
  phone
  pos
}

enum SaleStatus {
  quote
  pending
  paid
  cancelled
}

enum SaleOrigin {
  pos
  quote
  credit
}

enum ProductType {
  simple
  combo
  fabricable
}

enum UnitType {
  unit
  weight
  volume
  length
}

enum MoveType {
  in
  out
}

enum PmType {
  cash
  transfer
  zelle
  binance
  card
  other
}

enum Availability {
  in_stock
  low_stock
  out_of_stock
  discontinued
}

enum CatalogVisibility {
  visible
  hidden
  on_request
}

enum ReportStatus {
  pending
  generating
  ready
  failed
}

enum QuotationStatus {
  draft
  sent
  accepted
  rejected
  expired
}

enum ReturnStatus {
  pending
  approved
  rejected
}

// ── Modelos ────────────────────────────────────────────

model Business {
  id                   Int      @id @default(autoincrement())
  name                 String   @db.VarChar(255)
  legal_name           String?  @db.VarChar(255)
  rif                  String?  @db.VarChar(20)
  logo_path            String?
  address              String?
  city                 String?
  state                String?
  phone                String?
  email                String?
  theme                String   @default("dark")
  theme_color          String   @default("#2563EB")
  ticket_prefix        String   @default("ACT") @db.VarChar(10)
  ticket_footer        String?  @db.Text
  currency_default     String   @default("USD")
  rate_source          String   @default("bcv")
  subscription_active  Boolean  @default(true)
  onboarding_completed Boolean  @default(false)
  active               Boolean  @default(true)
  settings             Json?
  iva_enabled          Boolean  @default(false)
  iva_pct              Decimal  @default(16) @db.Decimal(5, 2)
  catalog_plan         String?  @db.VarChar(30)
  catalog_slug         String?  @unique @db.VarChar(80)
  catalog_active       Boolean  @default(false)
  catalog_title        String?  @db.VarChar(150)
  catalog_desc         String?  @db.Text
  segment              String?  @default("retail") @db.VarChar(40)
  cobro_data           Json?
  whatsapp             String?  @db.VarChar(30)
  max_discount_pct     Float    @default(0)
  created_at           DateTime @default(now())
  updated_at           DateTime @updatedAt

  users              User[]
  products           Product[]
  categories         Category[]
  sales              Sale[]
  cash_registers     CashRegister[]
  clients            Client[]
  payment_methods    PaymentMethod[]
  activity_logs      ActivityLog[]
  inventory_entries  InventoryEntry[]
  gastos             Gasto[]
  orders             Order[]
  dollar_rates       DollarRate[]
  monthly_reports    MonthlyReport[]
  quotations           Quotation[]
  returns              Return[]
  expense_categories   ExpenseCategory[]
  product_components   ProductComponent[]
  notifications        Notification[]

  @@map("businesses")
}

model User {
  id           Int      @id @default(autoincrement())
  business_id  Int
  name         String   @db.VarChar(255)
  email        String?  @db.VarChar(255)
  password     String   @db.VarChar(255)
  role         Role     @default(cashier)
  is_active    Boolean  @default(true)
  access_start String?  @db.VarChar(5)
  access_end   String?  @db.VarChar(5)
  access_days  Json?
  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt

  business      Business      @relation(fields: [business_id], references: [id])
  sales         Sale[]        @relation("SaleCashier")
  discount_auths Sale[]       @relation("SaleDiscountAuth")
  cash_registers CashRegister[]
  activity_logs ActivityLog[]
  cash_movements CashMovement[]
  inventory_entries InventoryEntry[]
  gastos        Gasto[]

  @@unique([business_id, email])
  @@map("users")
}

model Category {
  id          Int      @id @default(autoincrement())
  business_id Int
  name        String   @db.VarChar(80)
  color       String?  @db.VarChar(20)
  sort_order  Int      @default(0)
  active      Boolean  @default(true)

  business Business  @relation(fields: [business_id], references: [id])
  products Product[]

  @@unique([business_id, name], name: "name_business")
  @@map("categories")
}

model Product {
  id                  Int      @id @default(autoincrement())
  business_id         Int
  category_id         Int?
  name                String   @db.VarChar(120)
  barcode             String?  @db.VarChar(50)
  sku                 String?  @db.VarChar(50)
  description         String?  @db.Text
  sale_mode           SaleMode     @default(unit)
  product_type        ProductType  @default(simple)
  unit_type           UnitType     @default(unit)
  unit_label          String       @default("und") @db.VarChar(20)
  unit_step           Float        @default(1)
  base_unit_label     String       @default("und") @db.VarChar(20)
  price_per_kg_usd    Decimal? @db.Decimal(10, 2)
  price_per_unit_usd  Decimal? @db.Decimal(10, 2)
  cost_per_unit_usd   Decimal? @db.Decimal(10, 4)
  min_stock           Decimal  @default(0) @db.Decimal(8, 3)
  images              String?  @db.Text
  has_variants        Boolean  @default(false)
  show_in_catalog     Boolean  @default(false)
  available_in_pos    Boolean  @default(true)
  is_favorite         Boolean  @default(false)
  is_available        Boolean           @default(true)
  availability        Availability      @default(in_stock)
  catalog_visibility  CatalogVisibility @default(visible)
  active              Boolean           @default(true)
  badge               String?  @default("none")
  subcategory         String?
  is_featured         Boolean  @default(false)
  sort_order          Int      @default(0)
  created_at          DateTime @default(now())
  updated_at          DateTime @updatedAt

  business          Business          @relation(fields: [business_id], references: [id])
  category          Category?         @relation(fields: [category_id], references: [id])
  inventory_entries InventoryEntry[]
  sale_items        SaleItem[]
  variants          ProductVariant[]
  components        ProductComponent[] @relation("ComboComponents")
  usedIn            ProductComponent[] @relation("ComponentUsedIn")

  @@map("products")
}

model InventoryEntry {
  id                Int      @id @default(autoincrement())
  business_id       Int
  product_id        Int
  quantity          Decimal  @db.Decimal(10, 3)
  waste             Decimal  @default(0) @db.Decimal(10, 3)
  cost_per_unit_usd Decimal? @db.Decimal(10, 4)
  supplier          String?  @db.VarChar(120)
  notes             String?  @db.Text
  created_by        Int
  entered_at        DateTime @default(now())
  created_at        DateTime @default(now())

  business Business @relation(fields: [business_id], references: [id])
  product  Product  @relation(fields: [product_id], references: [id])
  user     User     @relation(fields: [created_by], references: [id])

  @@map("inventory_entries")
}

model Client {
  id          Int      @id @default(autoincrement())
  business_id Int
  name        String   @db.VarChar(120)
  phone       String?  @db.VarChar(20)
  email       String?  @db.VarChar(120)
  cedula      String?  @db.VarChar(15)
  notes       String?  @db.Text
  is_active   Boolean  @default(true)
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  business   Business    @relation(fields: [business_id], references: [id])
  sales      Sale[]
  orders     Order[]
  quotations Quotation[]

  @@map("clients")
}

model PaymentMethod {
  id          Int     @id @default(autoincrement())
  business_id Int
  name        String  @db.VarChar(60)
  type        PmType  @default(cash)
  is_active   Boolean @default(true)
  sort_order  Int     @default(0)

  business      Business       @relation(fields: [business_id], references: [id])
  sale_payments SalePayment[]
  sale_abonos   SaleAbono[]
  cash_movements CashMovement[]

  @@map("payment_methods")
}

model Sale {
  id              Int        @id @default(autoincrement())
  business_id     Int
  cashier_id      Int
  ticket_number   String     @db.VarChar(20)
  status          SaleStatus @default(pending)
  origin          SaleOrigin @default(pos)
  total_usd       Decimal    @db.Decimal(10, 2)
  total_bs        Decimal    @db.Decimal(12, 2)
  rate_used       Decimal    @db.Decimal(10, 4)
  client_id       Int?
  client_name     String?    @db.VarChar(120)
  client_phone    String?    @db.VarChar(20)
  notes           String?    @db.Text
  accounting_date     DateTime?  @db.Date
  sold_at             DateTime?
  discount_pct        Float      @default(0)
  discount_auth_by    Int?
  monto_recibido_usd  Float?
  vuelto_usd          Float?
  due_date            DateTime?
  credit_days         Int?
  credit_notes        String?    @db.Text
  created_at          DateTime   @default(now())
  updated_at          DateTime   @updatedAt

  business       Business      @relation(fields: [business_id], references: [id])
  cashier        User          @relation("SaleCashier", fields: [cashier_id], references: [id])
  client         Client?       @relation(fields: [client_id], references: [id])
  discount_auth  User?         @relation("SaleDiscountAuth", fields: [discount_auth_by], references: [id])
  items          SaleItem[]
  payments       SalePayment[]
  abonos         SaleAbono[]
  returns        Return[]

  @@map("sales")
}

model SaleItem {
  id                  Int     @id @default(autoincrement())
  sale_id             Int
  product_id          Int
  product_name        String  @db.VarChar(120)
  sale_mode           String  @db.VarChar(10)
  unit_label          String  @db.VarChar(20)
  quantity            Decimal @db.Decimal(10, 3)
  price_per_unit_usd  Decimal @db.Decimal(10, 4)
  subtotal_usd        Decimal @db.Decimal(10, 2)
  subtotal_bs         Decimal @db.Decimal(12, 2)
  rate_used           Decimal @db.Decimal(10, 4)
  discount_usd        Decimal  @default(0) @db.Decimal(10, 2)
  recipe_snapshot     String?  @db.Text
  variant_id          Int?

  sale    Sale            @relation(fields: [sale_id], references: [id])
  product Product         @relation(fields: [product_id], references: [id])
  variant ProductVariant? @relation(fields: [variant_id], references: [id])

  @@map("sale_items")
}

model SalePayment {
  id                Int      @id @default(autoincrement())
  sale_id           Int
  payment_method_id Int
  amount_bs         Decimal  @db.Decimal(12, 2)
  amount_usd        Decimal  @db.Decimal(10, 2)
  reference         String?  @db.VarChar(100)
  rate_used         Decimal  @db.Decimal(10, 4)
  created_at        DateTime @default(now())

  sale           Sale          @relation(fields: [sale_id], references: [id])
  payment_method PaymentMethod @relation(fields: [payment_method_id], references: [id])

  @@map("sale_payments")
}

model SaleAbono {
  id                Int      @id @default(autoincrement())
  sale_id           Int
  payment_method_id Int
  cash_register_id  Int?
  amount_bs         Decimal  @db.Decimal(12, 2)
  amount_usd        Decimal  @db.Decimal(10, 2)
  reference         String?  @db.VarChar(100)
  rate_used         Decimal  @db.Decimal(10, 4)
  notes             String?  @db.Text
  created_by        Int
  created_at        DateTime @default(now())

  sale           Sale           @relation(fields: [sale_id], references: [id])
  payment_method PaymentMethod  @relation(fields: [payment_method_id], references: [id])
  cash_register  CashRegister?  @relation(fields: [cash_register_id], references: [id])

  @@map("sale_abonos")
}

model CashRegister {
  id                   Int       @id @default(autoincrement())
  business_id          Int
  cashier_id           Int
  opening_amount_bs    Decimal   @default(0) @db.Decimal(12, 2)
  opening_amount_usd   Decimal   @default(0) @db.Decimal(10, 2)
  closing_amount_bs    Decimal?  @db.Decimal(12, 2)
  closing_amount_usd   Decimal?  @db.Decimal(10, 2)
  rate_at_open         Decimal   @db.Decimal(10, 4)
  opened_at            DateTime  @default(now())
  closed_at            DateTime?
  close_notes          String?   @db.Text

  business   Business       @relation(fields: [business_id], references: [id])
  cashier    User           @relation(fields: [cashier_id], references: [id])
  movements  CashMovement[]
  abonos     SaleAbono[]

  @@map("cash_registers")
}

model CashMovement {
  id                Int      @id @default(autoincrement())
  business_id       Int
  cash_register_id  Int
  payment_method_id Int?
  type              MoveType
  amount_bs         Decimal  @db.Decimal(12, 2)
  amount_usd        Decimal  @db.Decimal(10, 2)
  rate_used         Decimal  @db.Decimal(10, 4)
  concept           String   @db.VarChar(150)
  created_by        Int
  created_at        DateTime @default(now())

  cash_register  CashRegister   @relation(fields: [cash_register_id], references: [id])
  payment_method PaymentMethod? @relation(fields: [payment_method_id], references: [id])
  user           User           @relation(fields: [created_by], references: [id])

  @@map("cash_movements")
}

model DollarRate {
  id          Int      @id @default(autoincrement())
  business_id Int?
  rate        Decimal  @db.Decimal(10, 4)
  source      String   @default("bcv") @db.VarChar(20)
  is_active   Boolean  @default(true)
  fetched_at  DateTime @default(now())
  created_at  DateTime @default(now())

  business Business? @relation(fields: [business_id], references: [id])

  @@map("dollar_rates")
}

model ActivityLog {
  id          Int      @id @default(autoincrement())
  business_id Int
  user_id     Int
  action      String   @db.VarChar(60)
  model_type  String?  @db.VarChar(60)
  model_id    Int?
  reason      String?  @db.Text
  old_values  Json?
  new_values  Json?
  ip_address  String?  @db.VarChar(45)
  created_at  DateTime @default(now())

  business Business @relation(fields: [business_id], references: [id])
  user     User     @relation(fields: [user_id], references: [id])

  @@map("activity_logs")
}

model ExpenseCategory {
  id          Int      @id @default(autoincrement())
  business_id Int
  name        String   @db.VarChar(80)
  color       String?  @db.VarChar(7)
  is_system   Boolean  @default(false)
  active      Boolean  @default(true)
  created_at  DateTime @default(now())

  business Business @relation(fields: [business_id], references: [id])
  gastos   Gasto[]

  @@unique([business_id, name])
  @@map("expense_categories")
}

model Gasto {
  id           Int       @id @default(autoincrement())
  business_id  Int
  concepto     String    @db.VarChar(150)
  monto_usd    Decimal   @db.Decimal(10, 2)
  categoria    String    @default("otro") @db.VarChar(50)
  category_id  Int?
  fecha        DateTime  @db.Date
  notas        String?   @db.Text
  is_paid      Boolean   @default(true)
  paid_at      DateTime?
  created_by   Int
  created_at   DateTime  @default(now())

  business          Business         @relation(fields: [business_id], references: [id])
  creator           User             @relation(fields: [created_by], references: [id])
  expense_category  ExpenseCategory? @relation(fields: [category_id], references: [id])

  @@map("gastos")
}

model ProductVariant {
  id           Int      @id @default(autoincrement())
  product_id   Int
  tipo         String   @db.VarChar(30)
  valor        String   @db.VarChar(50)
  sku          String?  @db.VarChar(50)
  precio_extra Decimal  @default(0) @db.Decimal(10, 2)
  price_usd    Float?
  cost_usd     Float?
  stock        Int      @default(0)
  color_hex    String?  @db.VarChar(7)
  is_active    Boolean  @default(true)
  sort_order   Int      @default(0)
  created_at   DateTime @default(now())

  product    Product    @relation(fields: [product_id], references: [id])
  sale_items SaleItem[]

  @@map("product_variants")
}

model Order {
  id              Int          @id @default(autoincrement())
  business_id     Int
  order_number    String       @db.VarChar(20)
  status          OrderStatus  @default(received)
  origin          OrderOrigin  @default(whatsapp)
  client_id       Int?
  client_name     String?      @db.VarChar(120)
  client_phone    String?      @db.VarChar(20)
  client_address  String?      @db.Text
  notes           String?      @db.Text
  delivery_fee    Decimal      @default(0) @db.Decimal(10, 2)
  total_usd       Decimal      @db.Decimal(10, 2)
  total_bs        Decimal      @db.Decimal(12, 2)
  rate_used       Decimal      @db.Decimal(10, 4)
  estimated_time  Int?
  sale_id         Int?
  created_at      DateTime     @default(now())
  updated_at      DateTime     @updatedAt

  business  Business    @relation(fields: [business_id], references: [id])
  client    Client?     @relation(fields: [client_id], references: [id])
  items     OrderItem[]

  @@unique([business_id, order_number])
  @@map("orders")
}

model OrderItem {
  id                 Int     @id @default(autoincrement())
  order_id           Int
  product_id         Int
  product_name       String  @db.VarChar(120)
  variant_label      String? @db.VarChar(100)
  quantity           Decimal @db.Decimal(10, 3)
  price_per_unit_usd Decimal @db.Decimal(10, 4)
  subtotal_usd       Decimal @db.Decimal(10, 2)

  order Order @relation(fields: [order_id], references: [id])

  @@map("order_items")
}

model MonthlyReport {
  id               Int          @id @default(autoincrement())
  business_id      Int
  period           String       @db.VarChar(7)
  status           ReportStatus @default(pending)
  file_path        String?
  download_token   String?      @unique
  token_expires_at DateTime?
  generated_at     DateTime?
  notified_at      DateTime?
  created_at       DateTime     @default(now())
  updated_at       DateTime     @updatedAt

  business Business @relation(fields: [business_id], references: [id])

  @@unique([business_id, period])
  @@index([business_id])
  @@index([status])
  @@index([download_token])
  @@map("monthly_reports")
}

model Quotation {
  id           Int             @id @default(autoincrement())
  business_id  Int
  client_id    Int?
  number       String          @db.VarChar(30)
  status       QuotationStatus @default(draft)
  valid_until  DateTime?
  notes        String?         @db.Text
  subtotal_usd Decimal         @default(0) @db.Decimal(10, 2)
  total_usd    Decimal         @default(0) @db.Decimal(10, 2)
  rate_used    Decimal         @default(0) @db.Decimal(10, 4)
  total_bs     Decimal         @default(0) @db.Decimal(12, 2)
  created_at   DateTime        @default(now())
  updated_at   DateTime        @updatedAt

  business Business        @relation(fields: [business_id], references: [id])
  client   Client?         @relation(fields: [client_id], references: [id])
  items    QuotationItem[]

  @@index([business_id])
  @@map("quotations")
}

model QuotationItem {
  id           Int     @id @default(autoincrement())
  quotation_id Int
  product_id   Int?
  name         String  @db.VarChar(120)
  qty          Decimal @db.Decimal(10, 3)
  price_usd    Decimal @db.Decimal(10, 4)
  total_usd    Decimal @db.Decimal(10, 2)

  quotation Quotation @relation(fields: [quotation_id], references: [id], onDelete: Cascade)

  @@map("quotation_items")
}

model Return {
  id             Int          @id @default(autoincrement())
  business_id    Int
  sale_id        Int
  reason         String       @db.VarChar(500)
  status         ReturnStatus @default(pending)
  total_usd      Decimal      @db.Decimal(10, 2)
  total_bs       Decimal      @db.Decimal(12, 2)
  rate_used      Decimal      @db.Decimal(10, 4)
  restores_stock Boolean      @default(true)
  created_by     Int
  created_at     DateTime     @default(now())
  updated_at     DateTime     @updatedAt

  business Business    @relation(fields: [business_id], references: [id])
  sale     Sale        @relation(fields: [sale_id], references: [id])
  items    ReturnItem[]

  @@index([business_id])
  @@map("returns")
}

model ReturnItem {
  id         Int     @id @default(autoincrement())
  return_id  Int
  product_id Int
  qty        Decimal @db.Decimal(10, 3)
  price_usd  Decimal @db.Decimal(10, 4)
  total_usd  Decimal @db.Decimal(10, 2)

  return Return @relation(fields: [return_id], references: [id], onDelete: Cascade)

  @@map("return_items")
}

model ProductComponent {
  id           Int    @id @default(autoincrement())
  business_id  Int
  parent_id    Int
  component_id Int
  quantity     Float
  unit_label   String @default("und") @db.VarChar(20)

  business  Business @relation(fields: [business_id], references: [id])
  parent    Product  @relation("ComboComponents",   fields: [parent_id],    references: [id])
  component Product  @relation("ComponentUsedIn",   fields: [component_id], references: [id])

  @@unique([parent_id, component_id])
  @@index([business_id])
  @@index([parent_id])
  @@index([component_id])
  @@map("product_components")
}

model Notification {
  id          Int       @id @default(autoincrement())
  business_id Int
  type        String    @db.VarChar(60)
  title       String    @db.VarChar(150)
  body        String    @db.Text
  entity_type String?   @db.VarChar(60)
  entity_id   Int?
  channel     String    @default("in_app") @db.VarChar(20)
  status      String    @default("pending") @db.VarChar(20)
  created_at  DateTime  @default(now())
  read_at     DateTime?

  business Business @relation(fields: [business_id], references: [id])

  @@index([business_id, status])
  @@index([created_at])
  @@map("notifications")
}

model PinRateLimit {
  id          Int      @id @default(autoincrement())
  business_id Int
  sale_id     Int
  attempts    Int      @default(1)
  reset_at    DateTime
  created_at  DateTime @default(now())

  @@unique([business_id, sale_id])
  @@index([reset_at])
  @@map("pin_rate_limits")
}