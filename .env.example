# ──────────────────────────────────────────────────────────────
# ActivoPOS — Variables de entorno (PLANTILLA)
# Copia a .env.local (desarrollo) o .env.production (VPS) y rellena
# valores reales. NUNCA commitees archivos .env con secretos.
# ──────────────────────────────────────────────────────────────

# Base de datos (MariaDB)
DATABASE_URL="mysql://USER:PASSWORD@127.0.0.1:3306/activopos"
DB_HOST=127.0.0.1
DB_USER=root
DB_PASSWORD=
DB_NAME=activopos
DB_POOL=5

# Auth — JWT HS256, fail-closed. Genera un secreto fuerte y ÚNICO por entorno.
JWT_SECRET="<genera-un-secreto-fuerte-aqui>"

# URL pública de la app (catálogo, QR, links compartibles)
#   dev:  http://localhost:3000
#   prod: https://activopos.com
NEXT_PUBLIC_APP_URL="https://activopos.com"

# Tasa BCV
BCV_API_URL="https://ve.dolarapi.com/v1/dolares/oficial"
BCV_FALLBACK_RATE="36.50"

# Web Push (VAPID)
NEXT_PUBLIC_VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
VAPID_SUBJECT="mailto:admin@activopos.com"

# IA (Anthropic)
ANTHROPIC_API_KEY=""

# n8n (integración WhatsApp / reportes)
N8N_API_KEY=""

# SMTP (correo de confirmación de registro + alerta de nuevo negocio)
SMTP_HOST=""
SMTP_PORT=""
SMTP_USER=""
SMTP_PASSWORD=""
SMTP_FROM=""

# Generador de contenido social (panel admin — solo super_admin)
# Server-only: NUNCA prefijar con NEXT_PUBLIC_, expondría la key al bundle del cliente.
#
# Gemini: SOLO el copy (titulo/subtitulo/caption/hashtags). Su cuota de imagen es 0.
GEMINI_API_KEY=""
# NVIDIA NIM: la imagen de fondo (FLUX.1-dev). Misma key que usa el generador de blog.
NVIDIA_API_KEY=""

# Cloudinary — storage de las imágenes generadas (unsigned upload preset).
# CLOUD_NAME + UPLOAD_PRESET se consumen en src/lib/social/cloudinary.ts.
# API_KEY no se usa (el preset es unsigned), se deja por si se firma en el futuro.
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_UPLOAD_PRESET=""

# Buffer — publicación en redes (Fase E, aún no consumida por el código)
BUFFER_ACCESS_TOKEN=""

# Runtime
PORT=3002
NODE_ENV=production

# Tests / CIMAAD (solo .env.local)
CIMAAD_PASSWORD=""
